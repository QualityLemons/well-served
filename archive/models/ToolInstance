import uuid
from django.db import models
from django.conf import settings
from django.utils.timezone import now

class ToolInstance(models.Model):
    # Tactic 2: Access control at data level (User scoped)
    user = models.ForeignKey(
        settings.AUTH_USER_MODEL, 
        on_delete=models.CASCADE, 
        related_name='tool_instances'
    )
    
    # Tactic 3: Identification
    tool_slug = models.CharField(max_length=100) # e.g., 'summarizer'
    tool_version = models.CharField(max_length=20)
    
    # Tactic 4 & 5: State Management
    STATUS_CHOICES = [
        ('draft', 'Draft'),
        ('archived', 'Archived'),
    ]
    status = models.CharField(max_length=10, choices=STATUS_CHOICES, default='draft')
    
    # Tactic 2: Structured Data Storage
    # We use JSONField to store inputs and outputs flexibly
    payload_input = models.JSONField(default=dict, help_text="The raw user inputs.")
    payload_output = models.JSONField(default=dict, null=True, blank=True, help_text="The tool's result.")
    
    # Tactic 6: File References
    # Stores paths to generated static files
    html_file = models.FileField(upload_to='archives/html/', null=True, blank=True)
    md_file = models.FileField(upload_to='archives/md/', null=True, blank=True)
    rtf_file = models.FileField(upload_to='archives/rtf/', null=True, blank=True)
    
    # Timestamps
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    submitted_at = models.DateTimeField(null=True, blank=True)

    class Meta:
        ordering = ['-updated_at']

    def __str__(self):
        return f"{self.user.email} - {self.tool_slug} ({self.status})"

    def archive_record(self):
        """Tactic 5: Logic to transition draft to archive."""
        if self.status == 'draft':
            self.status = 'archived'
            self.submitted_at = now()
            self.save()
            